{
  "name": "tsilog",
  "version": "1.0.0-prerelease+do-not-use",
  "description": "Tasty logging for tasty TypeScript projects. Pronounced 'see-log'",
  "keywords": [
    "consola",
    "console",
    "debug",
    "debugger",
    "debugging",
    "error",
    "esm",
    "log",
    "logger",
    "logging",
    "log4ts",
    "reporter",
    "stacktrace",
    "trace",
    "tslog",
    "tsilog",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/castral/tsilog.git"
  },
  "license": "MIT",
  "author": "Ryan Brignoni",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "./dist/index.js",
    "./dist/index.js.map",
    "./dist/index.d.ts",
    "./dist/index.d.ts.map"
  ],
  "scripts": {
    "chk:coverage": "vitest --run --coverage.enabled=true --pool=threads",
    "chk:lint": "eslint . --cache --concurrency=off",
    "chk:typecheck": "tsc --noEmit --project tsconfig.prod.json",
    "dev:build": "tsc --project tsconfig.dev.json && vite build --mode development",
    "dev:clean": "rimraf -v dist node_modules coverage .eslintcache types pnpm-lock.yaml && pnpm install",
    "dev:test": "tsc --project tsconfig.spec.json && vitest --pool=threads --run --coverage.enabled=false",
    "prepare": "husky",
    "pub:jsr": "jsr publish",
    "pub:npm": "npm publish --access public",
    "tsi:build": "pnpm run tsi:verify && vite build --mode production",
    "tsi:release": "pnpm run tsi:build && pnpm run \"/^pub:.+/\"",
    "tsi:verify": "pnpm run \"/^chk:.+/\""
  },
  "dependencies": {
    "@castral/ts-enum": "1.1.0"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "7.57.7",
    "@stylistic/eslint-plugin": "5.8.0",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/eslint-plugin": "1.6.12",
    "eslint": "9.39.3",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-package-json": "0.89.3",
    "eslint-plugin-perfectionist": "5.5.0",
    "eslint-plugin-regexp": "3.0.0",
    "eslint-plugin-unicorn": "63.0.0",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "jsonc-eslint-parser": "3.1.0",
    "rimraf": "6.1.3",
    "typescript": "catalog:",
    "typescript-eslint": "8.56.2-alpha.1",
    "unplugin-dts": "file://../unplugin-dts/packages/unplugin-dts",
    "vite": "8.0.0",
    "vitest": "4.1.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "directory": "dist"
  }
}
