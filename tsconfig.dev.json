{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "./dist",
    "listEmittedFiles": true,
    "pretty": true,
    "sourceMap": true,
    "stripInternal": false
  },
  "include": [
    "lib/**/*.ts"
  ],
  "exclude": [
    "./lib/**/*.spec.ts"
  ]
}
